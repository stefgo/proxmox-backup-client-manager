{
    "name": "pbcm-client",
    "version": "1.0.0",
    "type": "module",
    "main": "dist/index.js",
    "scripts": {
        "prebuild": "rimraf dist",
        "start": "tsx src/index.ts",
        "dev": "tsx watch --conditions development src/index.ts",
        "build": "tsc && cp -r src/web/public dist/web/ && bash ../scripts/generate-version.sh dist/VERSION"
    },
    "dependencies": {
        "@fastify/static": "^9.0.0",
        "@pbcm/shared": "*",
        "@types/node-forge": "^1.3.14",
        "better-sqlite3": "^11.10.0",
        "fastify": "^5.8.1",
        "node-cron": "^4.2.1",
        "pino": "^10.3.1",
        "pino-pretty": "^13.1.3",
        "umzug": "^3.8.2",
        "ws": "^8.0.0",
        "yaml": "^2.7.0"
    },
    "devDependencies": {
        "@types/node": "^25.0.9",
        "@types/node-cron": "^3.0.11",
        "@types/pino": "^7.0.4",
        "@types/ws": "^8.18.1",
        "rimraf": "^6.1.3",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3"
    }
}
