{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Debug Server",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "runtimeExecutable": "node",
            "runtimeArgs": [
                "--import",
                "tsx",
                "src/index.ts"
            ],
            "cwd": "${workspaceFolder}/server/backend",
            "console": "integratedTerminal",
            "env": {}
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Debug Client",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "runtimeExecutable": "node",
            "runtimeArgs": [
                "--import",
                "tsx",
                "src/index.ts"
            ],
            "cwd": "${workspaceFolder}/client",
            "console": "integratedTerminal",
            "env": {
                "SERVER_URL": "wss://localhost:5173/ws"
            }
        },
        {
            "type": "chrome",
            "request": "launch",
            "name": "Debug Frontend",
            "url": "http://localhost:5173",
            "webRoot": "${workspaceFolder}/server/frontend/src",
            "preLaunchTask": "Start Frontend"
        }
    ],
    "compounds": [
        {
            "name": "Debug All",
            "configurations": [
                "Debug Server",
                "Debug Client",
                "Debug Frontend"
            ]
        }
    ]
}