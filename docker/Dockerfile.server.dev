# Basis-Image: Debian Bookworm (Native Arch / ARM64 friendly)
FROM debian:bookworm-slim

# Umgebungsvariablen setzen
ENV DEBIAN_FRONTEND=noninteractive

# Notwendige Pakete installieren
# Server benötigt Node.js, git, und Standard-Tools.
# Keine proxmox-backup-client Binaries hier, da Platform-spezifisch (und hier ARM64 möglich sein soll)
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
    wget \
    ca-certificates \
    gnupg \
    curl \
    git \
    vim \
    procps \
    iputils-ping \
    sqlite3 \
    lsb-release && \
    # Node.js 22.x Setup (via NodeSource)
    curl -fsSL https://deb.nodesource.com/setup_22.x | bash - && \
    apt-get update && \
    apt-get install -y --no-install-recommends \
    nodejs && \
    # Cleanup um das Image klein zu halten
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Arbeitsverzeichnis
WORKDIR /app

# Workspace-Struktur vorbereiten
# Wir kopieren zuerst die package.json Dateien, damit npm install gecached werden kann
COPY package.json package-lock.json .npmrc ./

# Verzeichnisse erstellen
RUN mkdir -p client shared server/frontend server/backend

# Kopieren der package.json Dateien der Workspaces
COPY client/package.json client/
COPY shared/package.json shared/
COPY server/backend/package.json server/backend/
COPY server/frontend/package.json server/frontend/

# Abhängigkeiten installieren (mit GitHub Packages Auth)
RUN --mount=type=secret,id=npm_token \
    NPM_TOKEN=$(cat /run/secrets/npm_token) npm install

# Quellcode von shared kopieren (vom Server benötigt)
COPY shared ./shared
# Server Code mounten wir zwar meistens, aber für den Build der Shared Lib brauchen wir context
# Wir kopieren hier nur das nötigste für den "Build" Schritt der Shared Libs, falls Server Code davon abhängt?
# Shared Lib baut sich selbst.

# Shared Library bauen (wird vom Server importiert)
RUN npm run build -w shared

# Standard-Kommando: Bash
CMD ["bash"]
